
---
import { Mail, Github, Linkedin, Instagram, FileText, Phone, MessageCircle } from 'lucide-react';
---

<section id="contact" class="py-24 px-4">
  <div class="max-w-4xl mx-auto text-center">
    <h2 class="text-4xl md:text-5xl font-bold mb-8 text-white">Get In Touch</h2>
<section id="contact" class="py-32 px-4 reveal">
  <div class="max-w-7xl mx-auto text-center">
    <h2 class="text-[10vw] font-bold text-primary mb-12 tracking-tighter">
      LET'S TALK
    </h2>
    
    <div class="flex flex-col md:flex-row justify-center gap-8 md:gap-16 mb-16">
      <a 
        href="mailto:ajvadaju2003@gmail.com" 
        class="text-2xl md:text-3xl text-muted hover:text-secondary transition-colors duration-300 border-b border-primary/20 pb-2 hover:border-secondary"
      >
        ajvadaju2003@gmail.com
      </a>
    </div>

    <div class="flex flex-col md:flex-row justify-center gap-8 mb-16">
      <a href="tel:+919497811519" class="flex items-center justify-center gap-3 text-muted hover:text-primary transition-colors group">
        <div class="p-3 rounded-full bg-primary/5 group-hover:bg-secondary/10 transition-colors">
          <Phone className="w-6 h-6" />
        </div>
        <span class="text-lg">+91 9497811519</span>
      </a>
      
      <a href="https://wa.me/917025394648" target="_blank" class="flex items-center justify-center gap-3 text-muted hover:text-primary transition-colors group">
        <div class="p-3 rounded-full bg-primary/5 group-hover:bg-secondary/10 transition-colors">
          <MessageCircle className="w-6 h-6" />
        </div>
        <span class="text-lg">+91 7025394648</span>
      </a>
    </div>

    <div class="flex justify-center gap-8 mt-16 mb-32">
      <a 
        href="https://github.com/Ajvadn" 
        target="_blank"
        rel="noopener noreferrer"
        class="p-4 rounded-full bg-primary/5 border border-primary/10 text-muted hover:text-primary hover:bg-secondary hover:border-secondary hover:scale-110 transition-all duration-300"
        aria-label="GitHub"
      >
        <Github className="w-6 h-6" />
      </a>
      <a 
        href="https://www.linkedin.com/in/ajvad-n/" 
        target="_blank"
        rel="noopener noreferrer"
        class="p-4 rounded-full bg-primary/5 border border-primary/10 text-muted hover:text-primary hover:bg-secondary hover:border-secondary hover:scale-110 transition-all duration-300"
        aria-label="LinkedIn"
      >
        <Linkedin className="w-6 h-6" />
      </a>
      <a 
        href="https://instagram.com/ajvad______" 
        target="_blank"
        rel="noopener noreferrer"
        class="p-4 rounded-full bg-primary/5 border border-primary/10 text-muted hover:text-primary hover:bg-secondary hover:border-secondary hover:scale-110 transition-all duration-300"
        aria-label="Instagram"
      >
        <Instagram className="w-6 h-6" />
      </a>
    </div>

    <footer class="text-muted/60 text-sm font-light">
      <p>&copy; {new Date().getFullYear()} AJVAD N. All rights reserved.</p>
    </footer>
  </div>
</section>
